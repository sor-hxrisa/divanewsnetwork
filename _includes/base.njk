<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — Diva News Network</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div id="intro-overlay">
    <div id="intro-flash"></div>
    <div class="intro-bar intro-bar-top"></div>
    <div class="intro-bar intro-bar-bottom"></div>
    <div class="intro-title">diva news network</div>
    <div class="intro-sub">breaking coverage</div>
  </div>

  <div class="masthead">
    <div>
      <h1>DIVA NEWS NETWORK</h1>
      <p>Est. 2026 · Exclusive Coverage</p>
    </div>
  </div>
  <nav>
    <a href="/">Home</a>
    <span>Sightings</span>
    <span>Style Watch</span>
    <span>Fan Desk</span>
    <span>Archive</span>
  </nav>
  <main>
    {{ content | safe }}
  </main>

  <script>
    window.addEventListener('load', function() {
      setTimeout(function() {
        var el = document.getElementById('intro-overlay');
        el.classList.add('hide');
        setTimeout(function() { el.remove(); }, 500);
      }, 1600);
    });
  </script>
</body>
</html>
